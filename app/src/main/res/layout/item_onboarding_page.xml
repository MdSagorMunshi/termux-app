<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="40dp"
    android:background="@color/terminux_onboarding_bg">

    <!-- Onboarding Image with glow ring -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp">

        <ImageView
            android:id="@+id/onboarding_image"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:src="@drawable/banner" />

    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/onboarding_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="26sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/terminux_on_bg"
        android:letterSpacing="0.02" />

    <!-- Description -->
    <TextView
        android:id="@+id/onboarding_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:textSize="15sp"
        android:lineSpacingMultiplier="1.4"
        android:fontFamily="sans-serif"
        android:textColor="@color/terminux_on_surface" />

    <!-- Optional Action Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/onboarding_action_button"
        style="@style/TerminuX.Button.Tonal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:visibility="gone"
        android:text="Action" />

</LinearLayout>
